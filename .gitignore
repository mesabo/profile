# Build output (deployed via site/Makefile to mesabo/mesabo.github.io)
site/build/

# Persistent deploy clone (preserves history + rollback tags)
site/.deploy/

# Auto-generated PDF thumbnails (regenerated from .pdf during build)
site/assets/papers/*.png
site/assets/awards/*.png

# Local source-quality backup of assets — NEVER deploy or commit
# (everything used by the site is already in site/assets/)
ressources/

# macOS
.DS_Store
**/.DS_Store

# Editor / IDE
.vscode/
.idea/
*.swp

# Python
__pycache__/
*.pyc
